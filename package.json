{
  "name": "@emby-chat/node-sdk",
  "version": "1.12.1",
  "description": "Official Node SDK for Emby Chat",
  "main": "index.js",
  "scripts": {
    "test": "node --test --test-reporter=spec 'test/unit/*.test.js' 'test/integration/*.test.js'",
    "test:watch": "node --test --watch 'test/unit/*.test.js' 'test/integration/*.test.js'",
    "coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=lcov --test-reporter-destination=coverage/lcov.info --test-reporter=spec --test-reporter-destination=stdout 'test/unit/*.test.js' 'test/integration/*.test.js'",
    "coverage:ci": "npm run coverage && node scripts/coverage-gate.js",
    "demo": "node --watch -r dotenv/config demo/index.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getchat-dev/node-sdk.git"
  },
  "keywords": [
    "emby",
    "sdk",
    "chat",
    "messaging",
    "conversation",
    "chatbots",
    "realtime"
  ],
  "author": "Evgeniy Tyurin",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/getchat-dev/node-sdk/issues"
  },
  "homepage": "https://github.com/getchat-dev/node-sdk#readme",
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "dotenv": "^16.0.0",
    "ejs": "^3.1.6",
    "express": "^4.18.1"
  }
}